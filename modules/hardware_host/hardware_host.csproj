<Project Sdk="Microsoft.NET.Sdk">
  <PropertyGroup>
    <OutputType>Exe</OutputType>
    <TargetFramework>net10.0</TargetFramework>
    <ImplicitUsings>enable</ImplicitUsings>
    <Nullable>enable</Nullable>
    <LangVersion>latest</LangVersion>
  </PropertyGroup>

  <ItemGroup>
    <Reference Include="LibreHardwareMonitor">
      <HintPath>..\LibreHardwareMonitor.dll</HintPath>
      <Private>true</Private>
    </Reference>
    <Reference Include="LibreHardwareMonitorLib">
      <HintPath>..\LibreHardwareMonitorLib.dll</HintPath>
      <Private>true</Private>
    </Reference>
  </ItemGroup>

  <ItemGroup>
    <None Include="..\*.dll" CopyToOutputDirectory="PreserveNewest" />
    <None Include="..\*.config" CopyToOutputDirectory="PreserveNewest" />
    <None Include="..\*.json" CopyToOutputDirectory="PreserveNewest" />
  </ItemGroup>
</Project>
